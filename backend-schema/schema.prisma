// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication - represents both school admins and parents
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phoneNumber String?  @unique
  password    String
  firstName   String
  lastName    String
  role        UserRole
  status      UserStatus @default(ACTIVE)
  
  // Profile information
  profilePictureUrl String?
  lastLoginAt       DateTime?
  emailVerifiedAt   DateTime?
  phoneVerifiedAt   DateTime?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  schoolAdmin      SchoolAdmin?
  parent           Parent?
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  activityLogs     ActivityLog[]

  @@map("users")
  @@index([email])
  @@index([role])
  @@index([status])
}

// School model - represents registered schools
model School {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  phoneNumber       String
  registrationNumber String?  @unique
  
  // Address information
  streetAddress     String
  city              String
  state             String
  localGovernment   String?
  postalCode        String?
  country           String    @default("Nigeria")
  
  // School configuration
  logoUrl           String?
  letterheadUrl     String?
  watermarkUrl      String?
  brandingEnabled   Boolean   @default(false)
  receiptTemplate   String    @default("standard")
  receiptColorScheme String   @default("blue")
  
  // Academic settings
  currentSession    String
  currentTerm       SchoolTerm
  
  // Status and verification
  status            SchoolStatus @default(PENDING_VERIFICATION)
  verificationCode  String?
  verifiedAt        DateTime?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  schoolAdmin       SchoolAdmin?
  wallet            Wallet?
  students          Student[]
  invoices          Invoice[]
  paymentStructures PaymentStructure[]
  classes           SchoolClass[]
  notifications     Notification[]
  activityLogs      ActivityLog[]

  @@map("schools")
  @@index([email])
  @@index([status])
  @@index([currentSession, currentTerm])
}

// School Admin model - links User to School
model SchoolAdmin {
  id       String @id @default(cuid())
  userId   String @unique
  schoolId String @unique
  
  // Admin specific fields
  position String @default("Administrator")
  permissions Json? // JSON array of permissions
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_admins")
}

// School Class model - represents different classes/grades
model SchoolClass {
  id       String @id @default(cuid())
  name     String // e.g., "Primary 1", "JSS 1", "SS 2"
  level    ClassLevel
  capacity Int?
  schoolId String
  
  // Academic year information
  session  String
  isActive Boolean @default(true)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students          Student[]
  paymentStructures PaymentStructure[]

  @@unique([schoolId, name, session])
  @@map("school_classes")
}

// Student model - students registered under schools
model Student {
  id               String  @id @default(cuid())
  admissionNumber  String  @unique
  firstName        String
  lastName         String
  middleName       String?
  dateOfBirth      DateTime
  gender           Gender
  
  // Contact information
  email            String?
  phoneNumber      String?
  
  // Address information
  address          String?
  city             String?
  state            String?
  
  // Academic information
  schoolId         String
  classId          String
  enrollmentDate   DateTime @default(now())
  
  // Additional information
  profilePictureUrl String?
  medicalInfo      Json? // JSON object for medical information
  emergencyContact Json? // JSON object for emergency contact details
  
  // Status
  status           StudentStatus @default(ACTIVE)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class      SchoolClass @relation(fields: [classId], references: [id])
  parent     Parent?   @relation(fields: [parentId], references: [id])
  parentId   String?
  invoices   Invoice[]
  payments   Payment[]

  @@map("students")
  @@index([schoolId])
  @@index([classId])
  @@index([admissionNumber])
  @@index([status])
}

// Parent model - automatically created when student is registered
model Parent {
  id          String   @id @default(cuid())
  userId      String   @unique
  
  // Parent-specific information
  relationship ParentRelationship
  occupation   String?
  workAddress  String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet      Wallet?
  students    Student[]
  payments    Payment[]
  notifications Notification[]

  @@map("parents")
}

// Wallet model - each school and parent has a wallet
model Wallet {
  id          String      @id @default(cuid())
  balance     Decimal     @default(0.00) @db.Decimal(15, 2)
  currency    String      @default("NGN")
  
  // Wallet owner information
  ownerId     String      @unique
  ownerType   WalletOwner
  
  // Status
  status      WalletStatus @default(ACTIVE)
  isLocked    Boolean     @default(false)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  school          School?           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId        String?           @unique
  parent          Parent?           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?           @unique
  transactions    WalletTransaction[]
  
  @@map("wallets")
  @@index([ownerType])
  @@index([status])
}

// Wallet Transaction model - tracks all wallet activities
model WalletTransaction {
  id            String              @id @default(cuid())
  walletId      String
  amount        Decimal             @db.Decimal(15, 2)
  type          TransactionType
  status        TransactionStatus   @default(PENDING)
  description   String
  reference     String              @unique
  
  // Transaction metadata
  metadata      Json?
  balanceBefore Decimal             @db.Decimal(15, 2)
  balanceAfter  Decimal             @db.Decimal(15, 2)
  
  // Related entities
  paymentId     String?
  invoiceId     String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@map("wallet_transactions")
  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([reference])
}

// Payment Structure model - defines fee structures for classes
model PaymentStructure {
  id          String @id @default(cuid())
  name        String
  description String?
  
  // Structure configuration
  schoolId    String
  classId     String?
  session     String
  term        SchoolTerm?
  
  // Status
  isActive    Boolean @default(true)
  isTemplate  Boolean @default(false)
  
  // Structure data
  structure   Json // JSON object containing fee items and amounts
  totalAmount Decimal @db.Decimal(15, 2)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    SchoolClass? @relation(fields: [classId], references: [id])
  invoices Invoice[]

  @@map("payment_structures")
  @@index([schoolId])
  @@index([classId])
  @@index([session, term])
  @@index([isActive])
}

// Invoice model - issued by schools to parents
model Invoice {
  id                    String        @id @default(cuid())
  invoiceNumber         String        @unique
  
  // Invoice details
  schoolId              String
  studentId             String
  paymentStructureId    String?
  
  // Financial information
  subtotal              Decimal       @db.Decimal(15, 2)
  discount              Decimal       @default(0.00) @db.Decimal(15, 2)
  totalAmount           Decimal       @db.Decimal(15, 2)
  paidAmount            Decimal       @default(0.00) @db.Decimal(15, 2)
  outstandingAmount     Decimal       @db.Decimal(15, 2)
  
  // Invoice metadata
  description           String?
  items                 Json          // JSON array of invoice line items
  
  // Academic information
  session               String
  term                  SchoolTerm
  
  // Status and dates
  status                InvoiceStatus @default(PENDING)
  issueDate             DateTime      @default(now())
  dueDate               DateTime
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  paymentStructure  PaymentStructure?  @relation(fields: [paymentStructureId], references: [id])
  payments          Payment[]
  walletTransactions WalletTransaction[]
  notifications     Notification[]

  @@map("invoices")
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([session, term])
  @@index([dueDate])
}

// Payment model - records of payments made by parents
model Payment {
  id                String            @id @default(cuid())
  reference         String            @unique
  
  // Payment details
  invoiceId         String
  studentId         String
  parentId          String
  amount            Decimal           @db.Decimal(15, 2)
  
  // Payment method and gateway
  method            PaymentMethod
  gateway           PaymentGateway?
  gatewayReference  String?
  
  // Payment status and verification
  status            PaymentStatus     @default(PENDING)
  verifiedAt        DateTime?
  
  // Transaction metadata
  metadata          Json?
  description       String?
  notes             String?
  
  // Timestamps
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  invoice           Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  student           Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent            Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
  receipts          Receipt[]
  walletTransactions WalletTransaction[]
  notifications     Notification[]

  @@map("payments")
  @@index([invoiceId])
  @@index([studentId])
  @@index([parentId])
  @@index([status])
  @@index([reference])
  @@index([method])
}

// Receipt model - generated for successful payments
model Receipt {
  id                String    @id @default(cuid())
  receiptNumber     String    @unique
  
  // Receipt details
  paymentId         String
  amount            Decimal   @db.Decimal(15, 2)
  
  // Receipt metadata
  receiptData       Json      // Comprehensive receipt information
  qrCodeData        String?   // QR code for verification
  
  // Status
  status            ReceiptStatus @default(ISSUED)
  
  // Timestamps
  issuedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("receipts")
  @@index([paymentId])
  @@index([receiptNumber])
  @@index([status])
}

// Notification model - for system notifications
model Notification {
  id         String             @id @default(cuid())
  title      String
  message    String
  type       NotificationType
  priority   NotificationPriority @default(NORMAL)
  
  // Recipient information
  recipientId   String
  recipientType RecipientType
  
  // Notification metadata
  data       Json?
  
  // Status
  isRead     Boolean @default(false)
  readAt     DateTime?
  
  // Timestamps
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String?
  parent   Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  school   School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String?
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String?
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId String?

  @@map("notifications")
  @@index([recipientId, recipientType])
  @@index([type])
  @@index([isRead])
  @@index([scheduledAt])
}

// Activity Log model - for tracking system activities
model ActivityLog {
  id          String       @id @default(cuid())
  action      String
  description String
  
  // Actor information
  actorId     String
  actorType   ActorType
  
  // Target information
  targetId    String?
  targetType  String?
  
  // Metadata
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  // Timestamps
  createdAt DateTime @default(now())
  
  // Relations
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId String?

  @@map("activity_logs")
  @@index([actorId, actorType])
  @@index([action])
  @@index([createdAt])
}

// Refresh Token model - for JWT token management
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// Enums

enum UserRole {
  SCHOOL_ADMIN
  PARENT
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  REJECTED
}

enum SchoolTerm {
  FIRST
  SECOND
  THIRD
}

enum ClassLevel {
  NURSERY
  PRIMARY
  JUNIOR_SECONDARY
  SENIOR_SECONDARY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
}

enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  UNCLE
  AUNT
  GRANDPARENT
  OTHER
}

enum WalletOwner {
  SCHOOL
  PARENT
}

enum WalletStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  REFUND
  TRANSFER
  FEE
  COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  WALLET
  CASH
  USSD
  QR_CODE
  MOBILE_MONEY
}

enum PaymentGateway {
  PAYSTACK
  FLUTTERWAVE
  INTERSWITCH
  REMITA
  NIBSS
  INTERNAL_WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum ReceiptStatus {
  ISSUED
  VOIDED
  REFUNDED
}

enum NotificationType {
  INVOICE_CREATED
  INVOICE_REMINDER
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  RECEIPT_ISSUED
  WALLET_CREDITED
  WALLET_DEBITED
  SYSTEM_ALERT
  ANNOUNCEMENT
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RecipientType {
  USER
  PARENT
  SCHOOL
  STUDENT
}

enum ActorType {
  USER
  SYSTEM
  ADMIN
}